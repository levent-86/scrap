{
  "manifest_version": 3,
  "name": "NeuraLetter Suite: Scrap",
  "version": "0.1.0",
  "description": "Manually collect data from websites. Set your CSV headers, copy info using the side panel, and export your organized list.",
  "permissions": ["tabs", "storage", "sidePanel", "scripting"],
  "action": {
    "default_title": "NeuraLetter Suite: Scrap",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/pick-16.png",
      "32": "icons/pick-32.png",
      "48": "icons/pick-48.png"
    }
  },
  "icons": {
    "16": "icons/pick-16.png",
    "32": "icons/pick-32.png",
    "48": "icons/pick-48.png",
    "128": "icons/pick-128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
